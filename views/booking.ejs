<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Room Bookings</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <h1>Room Bookings</h1>

  <div class="table-wrapper">
    <table>
      <thead>
        <tr>
          <th>Customer Name</th>
          <th>Room Number</th>
          <th>Start Time</th>
          <th>End Time</th>
          <th>Total Amount</th>
          <th>Actions</th>
        </tr>
      </thead>

      <tbody>
        <% if (bookings.length === 0) { %>
          <tr>
            <td colspan="6" class="empty-text">No bookings found</td>
          </tr>
        <% } else { %>
          <% bookings.forEach((booking) => { %>
            <tr>
              <td><%= booking.customerName %></td>
              <td><%= booking.roomNumber %></td>
              <td><%= new Date(booking.startTime).toLocaleString("en-US") %></td>
              <td><%= new Date(booking.endTime).toLocaleString("en-US") %></td>
              <td><%= booking.totalAmount %> VND</td>
              <td class="actions">
                <a href="/update-booking/<%= booking._id %>" class="btn btn-blue btn-small">
                  Update
                </a>

                <form 
                  action="/delete-booking/<%= booking._id %>" 
                  method="POST" 
                  class="inline-form"
                  onsubmit="return confirm('Are you sure you want to delete this booking?')"
                >
                  <button type="submit" class="btn btn-orange btn-small">
                    Delete
                  </button>
                </form>
              </td>
            </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>

  <div class="center">
    <a href="/book-room" class="btn btn-blue">Book a Room</a>
  </div>
</body>
</html>